# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_PATH=./time-off.sqlite

# HCM Integration
HCM_BASE_URL=http://localhost:4000
HCM_TIMEOUT_MS=4000
HCM_MAX_RETRIES=3

# HCM Webhook Security
HCM_WEBHOOK_SECRET=change-me-in-production
HCM_WEBHOOK_SECRET_PREV=

# Balance Cache
BALANCE_STALENESS_THRESHOLD_MINUTES=30
BALANCE_REFRESH_CRON=*/15 * * * *

# Retry Job
RETRY_JOB_CRON=*/5 * * * *
RETRY_JOB_MAX_ATTEMPTS=10

# Batch Sync
BATCH_CHUNK_SIZE=500
BATCH_MAX_RECORDS=100000
BATCH_MAX_BODY_SIZE_MB=50
